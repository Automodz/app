# Copy this file to `.env.local` and replace values with your own.
# Do NOT commit `.env.local` to git (it's already in `.gitignore`).

# ─── Firebase Configuration (get from Firebase project settings)
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# ─── Admin Login (email for admin user)
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ─── Business Info (optional)
NEXT_PUBLIC_UPI_ID=yourupi@bank
NEXT_PUBLIC_WHATSAPP_NUMBER=919xxxxxxxxx
NEXT_PUBLIC_SHOP_ADDRESS="Your shop address"
NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.app.goo.gl/yourlink

# ─── App URL (for links/redirects)
NEXT_PUBLIC_APP_URL=https://your-deployed-site.vercel.app
